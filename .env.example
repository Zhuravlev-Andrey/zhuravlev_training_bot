# Скопируйте этот файл в .env и заполните значения.
# .env НЕ должен попасть в git — он уже добавлен в .gitignore.

# Токен бота от @BotFather
TOKEN=your_telegram_bot_token_here

# URL подключения к PostgreSQL
# Локально: запустите PostgreSQL и укажите ваши данные
# На Railway: подставляется автоматически через Variable Reference
DATABASE_URL=postgresql://user:password@localhost:5432/training_bot

# Таймзона для отображения дат (опционально, по умолчанию Europe/Moscow)
TZ=Europe/Moscow

# Размер пула соединений с БД (опционально)
DB_POOL_MIN=1
DB_POOL_MAX=10
